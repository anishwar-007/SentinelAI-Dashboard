# Platform API (required)
NEXT_PUBLIC_SENTINELAI_API_URL=http://localhost:8000

# Supabase Auth (required for /dashboard)
# Prefer the anon/publishable key — never ship the service-role key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Landing / marketing CTAs
NEXT_PUBLIC_GITHUB_URL=https://github.com/anishwar-007/SentinelAI-Dashboard
